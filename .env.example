# ============================================================
# Environment Configuration — MAYUNG Ticketing System
# Copy this file to .env and adjust values for your environment
# ============================================================

# Database
DB_HOST=localhost
DB_USER=login_app_user
DB_PASSWORD=strongpassword
DB_NAME=login_app_db

# Server
PORT=3000
SESSION_SECRET=change_this_secret_key

# Fonnte WhatsApp Notification
# Daftar di https://fonnte.com dan dapatkan token dari dashboard
FONNTE_TOKEN=your_fonnte_token_here

# Environment (development / production / staging)
NODE_ENV=development
